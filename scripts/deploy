#!/usr/bin/env bash

# Deploy the application to Coolify without running tests.
#
# Usage:
#   scripts/deploy
#   SKIP_TESTS=true scripts/deploy


set -eo pipefail


IMAGE="ghcr.io/cite-me-in/cite.me.in:latest"
APP_UUID="myp73fab3pizwxq1coahwxqw"

SKIP_TESTS=false
for arg in "$@"; do
  if [ "$arg" = "--skip-tests" ]; then
    SKIP_TESTS=true
  fi
done

echo -e "\033[0;32m--- Step 1: Check (lint, types, secrets) ---\033[0m"
pnpm run check

echo -e "\033[0;32m--- Step 2: Push DB schema ---\033[0m"
pnpm prisma generate
pnpm prisma db push

if [[ -z "$SKIP_TESTS" ]]; then
  echo -e "\033[0;32m--- Step 3: Run tests ---\033[0m"
  pnpm vp test run

  echo -e "\033[0;32m--- Step 4: Run Playwright ---\033[0m"
  pnpm playwright test
else
  echo -e "\033[0;32m--- Skipping tests ---\033[0m"
fi

echo -e "\033[0;32m--- All checks passed. Deploying ---\033[0m"

echo -e "\033[0;32m--- Fetching production secrets from Infisical ---\033[0m"
infisical export --env prod --format=dotenv > .env.prod

COLIMA_WAS_RUNNING=true
if ! colima status &>/dev/null; then
  COLIMA_WAS_RUNNING=false
  echo "Starting colima..."
  colima start
fi
cleanup() {
  if [ "$COLIMA_WAS_RUNNING" = false ]; then
    echo "Stopping colima..."
    colima stop
  fi
}
trap cleanup EXIT

echo -e "\033[0;32m--- Building and pushing Docker image ---\033[0m"
docker buildx build --platform linux/amd64 --secret id=dotenv,src=.env.prod --push -t "$IMAGE" .

rm .env.prod

echo -e "\033[0;32m--- Triggering Coolify deployment ---\033[0m"
TOKEN=$(jq -r '.instances[0].token' ~/.config/coolify/config.json)
curl -s -X POST "https://coolify.labnotes.org/api/v1/deploy?type=application&uuid=$APP_UUID" \
  -H "Authorization: Bearer $TOKEN" | jq

echo -e "\033[0;34m--- Deployed to https://cite.me.in ---\033[0m"
open https://cite.me.in
