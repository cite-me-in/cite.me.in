#!/usr/bin/env bash

# Deploy the application to Coolify without running tests.
#
# Usage:
#   scripts/deploy
#   scripts/deploy --skip-tests

set -eo pipefail

echo -e "\033[0;32m--- Step 1: Check (lint, types, secrets) ---\033[0m"
pnpm run check

if [ "$1" = "--skip-tests" ]; then
  echo -e "\033[0;32m--- Skipping tests ---\033[0m"
else
  echo -e "\033[0;32m--- Step 2: Generate Prisma client ---\033[0m"
  infisical --env dev run --  pnpm prisma generate
  infisical --env dev run --  pnpm test:db:push

  echo -e "\033[0;32m--- Step 3: Run tests ---\033[0m"
  infisical --env test run -- pnpm vitest run

  echo -e "\033[0;32m--- Step 4: Run Playwright ---\033[0m"
  infisical --env test run -- pnpm playwright test
fi

echo -e "\033[0;32m--- Step 5: Update production database ---\033[0m"
infisical --env prod run -- pnpm prisma db push

echo -e "\033[0;32m--- Step 6: Generate cron config ---\033[0m"
infisical --env prod run -- tsx app/lib/cron/writeConfig.ts

echo -e "\033[0;32m--- Step 7: Build and push Docker image ---\033[0m"
infisical export --env prod --format=dotenv > .env
docker buildx build \
  --platform linux/amd64 \
  --push \
  -t ghcr.io/cite-me-in/cite.me.in:latest \
  .
rm -f .env

echo -e "\033[0;32m--- Step 8: Trigger Coolify deployment ---\033[0m"
infisical --env prod run -- coolify deploy name cite.me.in --force

echo -e "\033[0;32m--- Step 9: Sync cron tasks to Coolify ---\033[0m"
infisical --env prod run -- pnpm exec tsx app/lib/cron/syncTasks.ts \
  --coolify https://coolify.labnotes.org \
  --app cite.me.in

echo -e "\033[0;34m--- Deployed to https://cite.me.in ---\033[0m"
open https://cite.me.in
