#!/usr/bin/env bash

# Deploy the application to Coolify without running tests.
#
# Usage:
#   scripts/deploy
#   SKIP_TESTS=true scripts/deploy


set -eo pipefail


IMAGE="ghcr.io/cite-me-in/cite.me.in:latest"
APP_UUID="myp73fab3pizwxq1coahwxqw"

SKIP_TESTS=false
for arg in "$@"; do
  if [ "$arg" = "--skip-tests" ]; then
    SKIP_TESTS=true
  fi
done

echo "--- Step 1: Check (lint, types, secrets) ---"
pnpm run check


echo "--- Step 2: Push DB schema ---"
pnpm prisma generate
pnpm prisma db push


if [ -z "${SKIP_TESTS:-}" ]; then
  echo "--- Step 3: Run tests ---"
  pnpm vp test run

  echo "--- Step 4: Run Playwright ---"
  pnpm playwright test
fi


echo "--- All checks passed. Deploying ---"

COLIMA_WAS_RUNNING=true
if ! colima status &>/dev/null; then
  COLIMA_WAS_RUNNING=false
  echo "Starting colima..."
  colima start
fi
cleanup() {
  if [ "$COLIMA_WAS_RUNNING" = false ]; then
    echo "Stopping colima..."
    colima stop
  fi
}
trap cleanup EXIT

echo "Fetching production secrets from Infisical..."
infisical export --env prod --format=dotenv > .env.prod

echo "Building and pushing Docker image..."
docker buildx build --platform linux/amd64 --secret id=dotenv,src=.env.prod --push -t "$IMAGE" .

rm .env.prod

echo "Triggering Coolify deployment..."
TOKEN=$(jq -r '.instances[0].token' ~/.config/coolify/config.json)
curl -s -X POST "https://coolify.labnotes.org/api/v1/deploy?type=application&uuid=$APP_UUID" \
  -H "Authorization: Bearer $TOKEN" | jq

echo "Deployed to https://cite.me.in"
open https://cite.me.in
