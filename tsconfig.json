{
  "include": [
    ".react-router/types/**/*",
    "**/.client/**/*",
    "**/.server/**/*",
    "**/*",
    "test/**/*.ts"
  ],
  "exclude": [
    "__screenshots__/**",
    ".claude",
    ".github",
    ".vercel",
    ".vscode",
    "build/**",
    "docs/**",
    "node_modules/**",
    "package.json",
    "prisma/backup.sql",
    "prisma/generated",
    "public/**",
    "scripts/**"
  ],
  "compilerOptions": {
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "~/*": ["./app/*"],
      "~/prisma": ["./prisma/generated/client"],
      "~/prisma/seed": ["./prisma/seed/*"],
      "~/test/*": ["./test/*"]
    },
    "resolveJsonModule": true,
    "rootDirs": [".", "./.react-router/types"],
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vite/client"],
    "verbatimModuleSyntax": true
  }
}
