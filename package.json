    "radashi": "^12.7.2",
    "random-password-toolkit": "^1.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "respinner": "^5.0.0",
    "streamdown": "^2.5.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tiny-invariant": "^1.3.3",
