{
  "name": "cite.me.in",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "build": "prisma generate && react-router build --force && nub app/lib/cron/writeConfig.ts",
    "check": "./scripts/check",
    "clean": "nub install --force && rm -rf node_modules/.vite .react-router build",
    "dev": "infisical --env dev run -- portless run -- react-router dev",
    "fallow": "fallow",
    "prod:db:push": "infisical --env prod run -- nub exec prisma db push",
    "ready": "nub exec prisma generate && nub exec prisma db push && react-router typegen && nub app/lib/cron/writeConfig.ts",
    "start": "react-router-serve ./build/server/index.js",
    "test": "nub run check && nub run test:db:push && nub run test:reset && vp test run && playwright test",
    "test:db:push": "infisical --env test run -- nub exec prisma db push",
    "test:reset": "rm -rf __screenshots__/*"
  },
  "dependencies": {
