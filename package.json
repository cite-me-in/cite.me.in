{
  "name": "cite.me.in",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "build": "prisma generate && react-router build --force && tsx app/lib/cron/writeConfig.ts",
    "check": "secretlint --format stylish && react-router typegen && vp check --fix && infisical --env test run -- knip",
    "fallow": "fallow",
    "clean": "pnpm install --force && rm -rf node_modules/.vite .react-router build",
    "dev": "infisical --env test run -- portless run -- react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "test:db:push": "infisical --env test run -- pnpm prisma db push",
    "prod:db:push": "infisical --env prod run -- pnpm prisma db push",
    "test:reset": "rm -rf __screenshots__/*",
    "test": "NODE_OPTIONS=\"--localstorage-file /tmp/citeup-test-storage\" pnpm run check && pnpm test:db:push && pnpm test:reset && infisical --env test run -- vp test run && infisical --env test run -- playwright test",
    "ready": "pnpm prisma generate && pnpm prisma db push && pnpm react-router typegen && tsx app/lib/cron/writeConfig.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@base-ui/react": "^1.4.1",
    "@google/genai": "^2.2.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@logtail/node": "^0.5.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@perplexity-ai/perplexity_ai": "^0.27.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-router/fs-routes": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "@sentry/react-router": "^10.53.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "convert": "^7.0.0",
    "debug": "^4.4.3",
    "defuddle": "^0.18.1",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.10.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.14.0",
    "openai": "^6.37.0",
    "radashi": "^12.9.1",
    "random-password-toolkit": "^1.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-email": "^6.1.4",
    "react-router": "^7.15.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "respinner": "^5.0.0",
