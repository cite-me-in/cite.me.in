		"@react-router/serve": "^7.13.2",
		"@sentry/react-router": "^10.45.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@vercel/analytics": "^2.0.1",
		"@vercel/config": "^0.0.41",
