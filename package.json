{
  "name": "cite.me.in",
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "prisma generate && react-router build --force",
    "check:format": "biome format --write",
    "check:lint": "biome lint",
    "check:type": "react-router typegen && tsc --noEmit --strict",
    "check": "secretlint **/* --format stylish && pnpm check:lint && react-router typegen && tsc --noEmit --strict && knip",
    "clean": "pnpm install --force && rm -rf node_modules/.vite .react-router build",
    "clone": "./scripts/clone.sh",
    "dev": "react-router dev",
    "promote": "./scripts/promote.ts",
    "start": "react-router-serve ./build/server/index.js",
    "test:db:push": "infisical --env dev run -- pnpm prisma db push",
    "prod:db:push": "infisical --env prod run -- pnpm prisma db push",
    "test:reset": "rm -rf __screenshots__/*",
    "test": "pnpm run check && pnpm test:db:push && pnpm test:reset && pnpm --expose-gc --max-old-space-size=3096 vitest run && playwright test",
    "upgrade": "./scripts/upgrade.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/google": "^3.0.62",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/perplexity": "^3.0.29",
    "@base-ui/react": "^1.3.0",
    "@forge42/seo-tools": "^1.4.5",
    "@js-temporal/polyfill": "^0.5.1",
    "@logtail/node": "^0.5.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-email/components": "^1.0.12",
    "@react-router/fs-routes": "^7.14.0",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "@sentry/react-router": "^10.48.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "@vercel/config": "^0.1.1",
    "@vercel/react-router": "^1.2.6",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.158",
    "bcryptjs": "^3.0.3",
