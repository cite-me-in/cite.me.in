{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/components/layout/PageLayout.tsx",
    "app/components/ui/*.tsx",
    "app/cron/*.ts",
    "app/emails/sendEmails.tsx",
    "app/global.css",
    "scripts/*",
    "test/**/*.ts",
    "test/helpers/serverWorker.ts"
  ],
  "ignoreDependencies": [
    "@secretlint/secretlint-rule-preset-recommend",
    "coolify-ghcr-deploy",
    "oxfmt",
    "oxlint",
    "oxlint-tsgolint",
    "portless"
  ],
  "ignoreBinaries": ["redis-cli"],
  "ignoreFiles": ["app/lib/truncateWords.ts"],
  "ignoreIssues": {
    "app/lib/api/schemas.ts": ["exports"],
    "app/lib/html/parseHTML.ts": ["exports"],
    "app/lib/relativeTime.ts": ["exports"],
    "app/lib/formatDate.ts": ["exports"],
    "app/lib/truncateWords.ts": ["exports"]
  },
  "project": ["app/**/*.{ts,tsx}", "test/**/*.ts", "!__screenshots__"]
}
