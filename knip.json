{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/components/layout/PageLayout.tsx",
    "app/components/ui/*.tsx",
    "app/emails/sendEmails.tsx",
    "app/global.css",
    "scripts/*",
    "test/**/*.ts",
    "test/helpers/serverWorker.ts",
    "app/cron/*.ts"
  ],
  "project": ["app/**/*.ts", "app/**/*.tsx", "test/**/*.ts", "!__screenshots__"],
  "ignoreDependencies": ["@secretlint/secretlint-rule-preset-recommend", "portless", "@rolldown/binding-linux-x64-gnu", "@rolldown/binding-linux-x64-musl", "@voidzero-dev/vite-plus-darwin-arm64", "@voidzero-dev/vite-plus-darwin-x64", "@voidzero-dev/vite-plus-linux-arm64-gnu", "@voidzero-dev/vite-plus-linux-arm64-musl", "@voidzero-dev/vite-plus-linux-x64-gnu", "@voidzero-dev/vite-plus-linux-x64-musl", "@voidzero-dev/vite-plus-win32-arm64-msvc", "@voidzero-dev/vite-plus-win32-x64-msvc"],
  "ignoreFiles": ["app/lib/truncateWords.ts"],
  "ignoreIssues": {
    "app/lib/api/schemas.ts": ["exports"],
    "app/lib/html/parseHTML.ts": ["exports"],
    "app/lib/relativeTime.ts": ["exports"],
    "app/lib/formatDate.ts": ["exports"],
    "app/lib/truncateWords.ts": ["exports"]
  }
}
