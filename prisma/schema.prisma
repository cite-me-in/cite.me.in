generator client {
  provider               = "prisma-client"
  output                 = "generated"
  previewFeatures        = ["postgresqlExtensions"]
  engineType             = "client"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
  runtime                = "nodejs"
}

datasource db {
  provider     = "postgresql"
  relationMode = "foreignKeys"
}

model Account {
  createdAt            DateTime @map("created_at")             @default(now())
  id                   String                                  @id @default(cuid())
  interval             String   @map("interval")               @default("monthly")
  status               String   @map("status")
  stripeCustomerId     String   @map("stripe_customer_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  updatedAt            DateTime @map("updated_at")             @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String   @map("user_id")                @unique

  @@map("accounts")
}

model BotInsight {
  content     String   @map("content")
  createdAt   DateTime @map("created_at")   @default(now())
  generatedAt DateTime @map("generated_at")
  id          String                        @id @default(cuid())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String   @map("site_id")      @unique
  updatedAt   DateTime @map("updated_at")   @updatedAt

  @@map("bot_insights")
}

model BotVisit {
  accept    String[] @map("accept")
  botType   String   @map("bot_type")
  count     Int      @map("count")      @default(1)
  createdAt DateTime @map("created_at") @default(now())
  date      DateTime @map("date")
  firstSeen DateTime @map("first_seen") @default(now())
  id        String                      @id @default(cuid())
  ip        String?  @map("ip")
  lastSeen  DateTime @map("last_seen")  @default(now())
  path      String   @map("path")
  referer   String?  @map("referer")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  userAgent String   @map("user_agent")

  @@unique([date, siteId, userAgent, path])
  @@index([siteId])
  @@map("bot_visits")
}

model CitationQuery {
  citations    String[]         @map("citations")
  createdAt    DateTime         @map("created_at")    @default(now())
  extraQueries String[]         @map("extra_queries")
  group        String           @map("group")
  id           String                                 @id @default(cuid())
  query        String           @map("query")
  run          CitationQueryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId        String           @map("run_id")
  text         String           @map("text")

  @@index([runId])
  @@map("citation_queries")
}

model CitationQueryRun {
  onDate           String          @map("on_date") // ISO 8601 date string
  id               String                                                  @id @default(cuid())
  model            String          @map("model")
  platform         String          @map("platform")
  queries          CitationQuery[]
  sentimentLabel   SentimentLabel? @map("sentiment_label")
  sentimentSummary String?         @map("sentiment_summary")
  site             Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId           String          @map("site_id")

  @@map("citation_query_runs")
  @@unique([siteId, platform,onDate])
}

model EmailVerificationToken {
  createdAt DateTime  @map("created_at") @default(now())
  expiresAt DateTime  @map("expires_at")
  id        String                       @id @default(cuid())
  token     String    @map("token")      @unique
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")

  @@index([userId])
  @@map("email_verification_tokens")
}

model HumanVisit {
  aiReferral String?  @map("ai_referral")
  browser    String   @map("browser")
  count      Int      @map("count")       @default(1)
  createdAt  DateTime @map("created_at")  @default(now())
  date       DateTime @map("date")
  deviceType String   @map("device_type")
  firstSeen  DateTime @map("first_seen")  @default(now())
  id         String                       @id @default(cuid())
  lastSeen   DateTime @map("last_seen")   @default(now())
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId     String   @map("site_id")
  updatedAt  DateTime @map("updated_at")  @updatedAt
  visitorId  String   @map("visitor_id")

  @@unique([date, siteId, visitorId])
  @@index([siteId])
  @@map("human_visits")
}

model PasswordRecoveryToken {
  createdAt DateTime  @map("created_at") @default(now())
  expiresAt DateTime  @map("expires_at")
  id        String                       @id @default(cuid())
  token     String    @map("token")      @unique
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")

  @@index([userId])
  @@map("password_recovery_tokens")
}

model Session {
  createdAt   DateTime @map("created_at")                                        @default(now())
  id          String                                                             @id @default(cuid())
  ipAddress   String?  @map("ip_address")
  referer     String?  @map("referer") // misspelled for backwards compatibility
  token       String   @map("token")                                             @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent   String?  @map("user_agent")
  userId      String   @map("user_id")
  utmCampaign String?  @map("utm_campaign")
  utmContent  String?  @map("utm_content")
  utmMedium   String?  @map("utm_medium")
  utmSource   String?  @map("utm_source")
  utmTerm     String?  @map("utm_term")

  @@index([userId])
  @@map("sessions")
}

model Site {
  apiKey               String                @map("api_key")    @unique @default("")
  botInsight           BotInsight?
  botVisits            BotVisit[]
  citationRuns         CitationQueryRun[]
  content              String                @map("content")
  createdAt            DateTime              @map("created_at") @default(now())
  domain               String                @map("domain")
  humanVisits          HumanVisit[]
  id                   String                                   @id @default(cuid())
  owner                User                  @relation("OwnedSites", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId              String                @map("owner_id")
  siteInvitations      SiteInvitation[]
  siteQueries          SiteQuery[]
  siteQuerySuggestions SiteQuerySuggestion[]
  siteUsers            SiteUser[]
  serpRuns             SerpRun[]
  summary              String                @map("summary")
  updatedAt            DateTime              @map("updated_at") @updatedAt
  usageEvents          UsageEvent[]

  @@index([domain])
  @@unique([ownerId,   domain])
  @@map("sites")
}

model SiteInvitation {
  acceptedAt  DateTime?        @map("accepted_at")
  createdAt   DateTime         @map("created_at")    @default(now())
  email       String           @map("email")
  id          String                                 @id @default(cuid())
  invitedBy   User             @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedById String           @map("invited_by_id")
  site        Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String           @map("site_id")
  status      InvitationStatus                       @default(PENDING)
  token       String           @map("token")         @unique

  @@index([siteId])
  @@index([email])
  @@map("site_invitations")
}

model SiteQuery {
  createdAt DateTime @map("created_at") @default(now())
  group     String   @map("group")
  id        String                      @id @default(cuid())
  query     String   @map("query")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  updatedAt DateTime @map("updated_at") @updatedAt

  @@index([siteId])
  @@map("site_queries")
}

model SiteQuerySuggestion {
  createdAt DateTime @map("created_at") @default(now())
  group     String   @map("group")
  id        String                      @id @default(cuid())
  query     String   @map("query")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  updatedAt DateTime @map("updated_at") @updatedAt

  @@index([siteId])
  @@map("site_query_suggestions")
}

model SiteUser {
  createdAt DateTime @map("created_at") @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")

  @@id([siteId, userId])
  @@map("site_users")
}

model UsageEvent {
  cost         Decimal  @map("cost")          @db.Decimal(10, 6)
  createdAt    DateTime @map("created_at")    @default(now())
  id           String                         @id @default(cuid())
  inputTokens  Int      @map("input_tokens")  @default(0)
  model        String   @map("model")
  outputTokens Int      @map("output_tokens") @default(0)
  siteId       String   @map("site_id")
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@map("usage_events")
}

model User {
  account                 Account?
  apiKey                  String?                  @map("api_key")           @unique
  createdAt               DateTime                 @map("created_at")        @default(now())
  email                   String                   @map("email")             @unique
  emailVerificationTokens EmailVerificationToken[]
  emailVerifiedAt         DateTime?                @map("email_verified_at")
  id                      String                                             @id @default(cuid())
  isAdmin                 Boolean                  @map("is_admin")          @default(false)
  ownedSites              Site[]                   @relation("OwnedSites")
  passwordHash            String                   @map("password_hash")
  passwordRecoveryTokens  PasswordRecoveryToken[]
  sentInvitations         SiteInvitation[]         @relation("SentInvitations")
  sessions                Session[]
  siteUsers               SiteUser[]
  unsubscribed            Boolean                  @map("unsubscribed")      @default(false)
  updatedAt               DateTime                 @map("updated_at")        @updatedAt

  @@map("users")
}

model SerpRun {
  id        String      @id @default(cuid())
  onDate    String      @map("on_date")
  queries   SerpQuery[]
  site      Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String      @map("site_id")
  source    String      @map("source")
  updatedAt DateTime    @map("updated_at") @updatedAt

  @@unique([siteId, source, onDate])
  @@index([siteId])
  @@map("serp_runs")
}

model SerpQuery {
  aioPresent Boolean  @map("aio_present")
  citations  String[] @map("citations")
  createdAt  DateTime @map("created_at") @default(now())
  group      String   @map("group")
  id         String   @id @default(cuid())
  query      String   @map("query")
  run        SerpRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String   @map("run_id")

  @@index([runId])
  @@map("serp_queries")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum SentimentLabel {
  positive
  negative
  neutral
  mixed
}
