generator client {
  provider               = "prisma-client"
  output                 = "generated"
  previewFeatures        = ["postgresqlExtensions"]
  engineType             = "client"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
  runtime                = "nodejs"
}

datasource db {
  provider     = "postgresql"
  relationMode = "foreignKeys"
}

/**
 * The Account model is a pure Stripe metadata store for a user's account
 * (`stripeCustomerId`, `stripeSubscriptionId`, `interval`).
 */
model Account {
  createdAt            DateTime @map("created_at")             @default(now())
  id                   String                                  @id @default(cuid())
  interval             String   @map("interval")               @default("monthly")
  stripeCustomerId     String   @map("stripe_customer_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  updatedAt            DateTime @map("updated_at")             @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String   @map("user_id")                @unique

  @@map("accounts")
}

/**
 * The BotInsight model is a record of a bot insight generated for a site.
 */
model BotInsight {
  content     String   @map("content")
  createdAt   DateTime @map("created_at")   @default(now())
  generatedAt DateTime @map("generated_at")
  id          String                        @id @default(cuid())
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String   @map("site_id")      @unique
  updatedAt   DateTime @map("updated_at")   @updatedAt

  @@map("bot_insights")
}

/**
 * The BotVisit model is a record of a bot visit to a site.
 */
model BotVisit {
  accept    String[] @map("accept")
  botType   String   @map("bot_type")
  count     Int      @map("count")      @default(1)
  createdAt DateTime @map("created_at") @default(now())
  date      DateTime @map("date")
  firstSeen DateTime @map("first_seen") @default(now())
  id        String                      @id @default(cuid())
  ip        String?  @map("ip")
  lastSeen  DateTime @map("last_seen")  @default(now())
  path      String   @map("path")
  referer   String?  @map("referer")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  userAgent String   @map("user_agent")

  @@unique([date, siteId, userAgent, path])
  @@index([siteId])
  @@map("bot_visits")
}

/**
 * Used to track a query result for a citation query run.
 */
model CitationQuery {
  citations    String[]         @map("citations")
  createdAt    DateTime         @map("created_at")    @default(now())
  extraQueries String[]         @map("extra_queries")
  group        String           @map("group")
  id           String                                 @id @default(cuid())
  query        String           @map("query")
  run          CitationQueryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId        String           @map("run_id")
  text         String           @map("text")

  @@index([runId])
  @@map("citation_queries")
}

/**
 * Used to track citation query runs for a site.
 */
model CitationQueryRun {
  onDate           String          @map("on_date") // ISO 8601 date string
  id               String                                                  @id @default(cuid())
  model            String          @map("model")
  platform         String          @map("platform")
  queries          CitationQuery[]
  sentimentLabel   SentimentLabel? @map("sentiment_label")
  sentimentSummary String?         @map("sentiment_summary")
  site             Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId           String          @map("site_id")

  @@map("citation_query_runs")
  @@unique([siteId, platform,onDate])
}

/**
 * Used to track human visits to a site.
 */
model HumanVisit {
  aiReferral String?  @map("ai_referral")
  browser    String   @map("browser")
  count      Int      @map("count")       @default(1)
  createdAt  DateTime @map("created_at")  @default(now())
  date       DateTime @map("date")
  deviceType String   @map("device_type")
  firstSeen  DateTime @map("first_seen")  @default(now())
  id         String                       @id @default(cuid())
  lastSeen   DateTime @map("last_seen")   @default(now())
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId     String   @map("site_id")
  updatedAt  DateTime @map("updated_at")  @updatedAt
  visitorId  String   @map("visitor_id")

  @@unique([date, siteId, visitorId])
  @@index([siteId])
  @@map("human_visits")
}

/**
 * Used to reset a user's password.
 */
model PasswordRecoveryToken {
  createdAt DateTime  @map("created_at") @default(now())
  expiresAt DateTime  @map("expires_at")
  id        String                       @id @default(cuid())
  token     String    @map("token")      @unique
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")

  @@index([userId])
  @@map("password_recovery_tokens")
}

/**
 * Used to track user sessions.  Sessions are created when a user signs in and
 * are deleted when a user signs out.
 */
model Session {
  createdAt   DateTime @map("created_at")                                        @default(now())
  id          String                                                             @id @default(cuid())
  ipAddress   String?  @map("ip_address")
  referer     String?  @map("referer") // misspelled for backwards compatibility
  token       String   @map("token")                                             @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent   String?  @map("user_agent")
  userId      String   @map("user_id")
  utmCampaign String?  @map("utm_campaign")
  utmContent  String?  @map("utm_content")
  utmMedium   String?  @map("utm_medium")
  utmSource   String?  @map("utm_source")
  utmTerm     String?  @map("utm_term")

  @@index([userId])
  @@map("sessions")
}

/**
 * The Site model is a record of a site. The owner of the site is the user who
 * created the site and can invite other users to view site metrics. API key is
 * used to authenticate API requests that track bot and human visits.
 */
model Site {
  apiKey               String                @map("api_key")           @unique @default("")
  botInsight           BotInsight?
  botVisits            BotVisit[]
  citationRuns         CitationQueryRun[]
  content              String                @map("content")
  createdAt            DateTime              @map("created_at")        @default(now())
  digestSentAt         DateTime?             @map("digest_sent_at")
  domain               String                @map("domain")
  humanVisits          HumanVisit[]
  id                   String                                          @id @default(cuid())
  lastProcessedAt      DateTime?             @map("last_processed_at")
  owner                User                  @relation("OwnedSites", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId              String                @map("owner_id")
  siteInvitations      SiteInvitation[]
  siteQueries          SiteQuery[]
  siteQuerySuggestions SiteQuerySuggestion[]
  siteUsers            SiteUser[]
  summary              String                @map("summary")
  updatedAt            DateTime              @map("updated_at")        @updatedAt
  usageEvents          UsageEvent[]

  @@index([domain])
  @@unique([ownerId,   domain])
  @@map("sites")
}

/**
 * Used to invite a user to access a site.
 */
model SiteInvitation {
  acceptedAt  DateTime?        @map("accepted_at")
  createdAt   DateTime         @map("created_at")    @default(now())
  email       String           @map("email")
  id          String                                 @id @default(cuid())
  invitedBy   User             @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedById String           @map("invited_by_id")
  site        Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId      String           @map("site_id")
  status      InvitationStatus                       @default(PENDING)
  token       String           @map("token")         @unique

  @@index([siteId])
  @@index([email])
  @@map("site_invitations")
}

/**
 * A site query — ask LLM the query and see how many citations it returns.
 */
model SiteQuery {
  createdAt DateTime @map("created_at") @default(now())
  group     String   @map("group")
  id        String                      @id @default(cuid())
  query     String   @map("query")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  updatedAt DateTime @map("updated_at") @updatedAt

  @@index([siteId])
  @@map("site_queries")
}

/**
 * Suggestions for site queries generated by the AI.
 */
model SiteQuerySuggestion {
  createdAt DateTime @map("created_at") @default(now())
  group     String   @map("group")
  id        String                      @id @default(cuid())
  query     String   @map("query")
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  updatedAt DateTime @map("updated_at") @updatedAt

  @@index([siteId])
  @@map("site_query_suggestions")
}

/**
 * A user who has access to a site.
 */
model SiteUser {
  createdAt DateTime @map("created_at") @default(now())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String   @map("site_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")

  @@id([siteId, userId])
  @@map("site_users")
}

/**
 * Usage of an API (LLM, SerpAPI, etc.) for limiting usage.
 */
model UsageEvent {
  cost         Decimal  @map("cost")          @db.Decimal(10, 6)
  createdAt    DateTime @map("created_at")    @default(now())
  id           String                         @id @default(cuid())
  inputTokens  Int      @map("input_tokens")  @default(0)
  model        String   @map("model")
  outputTokens Int      @map("output_tokens") @default(0)
  siteId       String   @map("site_id")
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, createdAt])
  @@map("usage_events")
}

/**
 * A user of the cite.me.in platform.
 */
model User {
  account                Account?
  apiKey                 String?                 @map("api_key")           @unique
  createdAt              DateTime                @map("created_at")        @default(now())
  email                  String                  @map("email")             @unique
  emailVerifiedAt        DateTime?               @map("email_verified_at")
  id                     String                                            @id @default(cuid())
  isAdmin                Boolean                 @map("is_admin")          @default(false)
  ownedSites             Site[]                  @relation("OwnedSites")
  passwordHash           String                  @map("password_hash")
  plan                   Plan                    @map("plan")              @default(trial)
  passwordRecoveryTokens PasswordRecoveryToken[]
  sentInvitations        SiteInvitation[]        @relation("SentInvitations")
  sessions               Session[]
  siteUsers              SiteUser[]
  unsubscribed           Boolean                 @map("unsubscribed")      @default(false)
  updatedAt              DateTime                @map("updated_at")        @updatedAt
  webhookEndpoints       WebhookEndpoint[]
  sentEmails             SentEmail[]

  @@map("users")
}

/**
 * A delivery attempt to a webhook.
 */
model WebhookDelivery {
  id          String                                @id @default(cuid())
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  endpointId  String          @map("endpoint_id")
  eventType   String          @map("event_type")
  payload     Json            @map("payload")
  status      DeliveryStatus  @map("status")        @default(PENDING)
  attempts    Int             @map("attempts")      @default(0)
  nextRetryAt DateTime?       @map("next_retry_at")
  lastError   String?         @map("last_error")
  createdAt   DateTime        @map("created_at")    @default(now())
  updatedAt   DateTime        @map("updated_at")    @updatedAt

  @@index([status, nextRetryAt])
  @@index([endpointId])
  @@map("webhook_deliveries")
}

/**
 * A webhook endpoint — a URL to send webhooks to.
 */
model WebhookEndpoint {
  id         String                               @id @default(cuid())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String            @map("user_id")
  url        String            @map("url")
  secret     String            @map("secret")
  events     String[]          @map("events")
  isActive   Boolean           @map("is_active")  @default(true)
  createdAt  DateTime          @map("created_at") @default(now())
  updatedAt  DateTime          @map("updated_at") @updatedAt
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhook_endpoints")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum SentimentLabel {
  positive
  negative
  neutral
  mixed
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  RETRY
  FAILED
}

enum Plan {
  trial     // First 25 days — weekly processing and digest, then stops
  paid      // Active subscription — daily processing, weekly digest
  cancelled // Subscription ended — no processing, no digest
  gratis    // Manually granted — daily processing, weekly digest, no subscription required
}

model SentEmail {
  id     String                   @id @default(cuid())
  sentAt DateTime @map("sent_at") @default(now())
  type   String   @map("type")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String   @map("user_id")

  @@index([userId, type])
  @@map("sent_emails")
}
